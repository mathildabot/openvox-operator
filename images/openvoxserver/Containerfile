# Rootless OpenVox Server on UBI9 for Kubernetes/OpenShift
# No ezbake, no runuser/su/sudo — direct Java startup as the running user.
#
# Build:
#   podman build -t openvoxserver:rootless .
#
# Run (default user 1001:0):
#   podman run --rm -e USE_OPENVOXDB=false openvoxserver:rootless
#
# Run with random UID (OpenShift simulation):
#   podman run --rm --user 12345:0 -e USE_OPENVOXDB=false openvoxserver:rootless

################################################################################
# Stage: base — JRE + minimal runtime deps
################################################################################
FROM registry.access.redhat.com/ubi9/ubi-minimal AS base

ARG JDK_VERSION=17

RUN microdnf install -y \
        java-${JDK_VERSION}-openjdk-headless \
        bash \
        curl-minimal \
        openssl \
    && microdnf clean all

################################################################################
# Stage: build — install tarball contents
################################################################################
FROM base AS build

ARG OPENVOXSERVER_VERSION=8.12.1
ARG OPENVOXDB_VERSION=8.12.1

ADD https://artifacts.voxpupuli.org/openvox-server/${OPENVOXSERVER_VERSION}/openvox-server-${OPENVOXSERVER_VERSION}.tar.gz /
ADD https://artifacts.voxpupuli.org/openvoxdb/${OPENVOXDB_VERSION}/openvoxdb-${OPENVOXDB_VERSION}.tar.gz /

ENV app_logdir=/var/log/puppetlabs \
    apps_dir=/opt/puppetlabs/server/apps \
    data_dir=/opt/puppetlabs/server/data \
    etc_dir=/etc/puppetlabs \
    run_dir=/var/run/puppetlabs \
    bindir=/opt/puppetlabs/server/apps/puppetserver/bin \
    symbindir=/opt/puppetlabs/server/bin \
    uxbindir=/opt/puppetlabs/bin \
    rubylibdir=/opt/puppetlabs/puppet/lib/ruby/vendor_ruby

RUN tar -xzf /openvox-server-${OPENVOXSERVER_VERSION}.tar.gz \
    && tar -xzf /openvoxdb-${OPENVOXDB_VERSION}.tar.gz \
    && cd /puppetserver-${OPENVOXSERVER_VERSION} \
    # --- directory structure ---
    && install -d -m 0755 "${app_logdir}/puppetserver" \
    && install -d -m 0755 "${data_dir}/puppetserver/jars" \
    && install -d -m 0755 "${data_dir}/puppetserver/yaml" \
    && install -d -m 0755 "${etc_dir}/puppetserver/ca" \
    && install -d -m 0755 "${apps_dir}/puppetserver" \
    && install -d -m 0755 "${apps_dir}/puppetserver/cli" \
    && install -d -m 0755 "${apps_dir}/puppetserver/cli/apps" \
    && install -d -m 0755 "${apps_dir}/puppetserver/config/services.d" \
    && install -d -m 0755 "${bindir}" \
    && install -d -m 0755 "${data_dir}/puppetserver/jruby-gems" \
    && install -d -m 0755 "${etc_dir}/code" \
    && install -d -m 0755 "${etc_dir}/code/environments" \
    && install -d -m 0755 "${etc_dir}/puppet" \
    && install -d -m 0755 "${etc_dir}/puppet/ssl" \
    && install -d -m 0755 "${etc_dir}/puppetserver/conf.d" \
    && install -d -m 0755 "${etc_dir}/puppetserver/services.d" \
    && install -d -m 0755 "${run_dir}/puppetserver" \
    && install -d -m 0755 "${symbindir}" \
    && install -d -m 0755 "${uxbindir}" \
    && install -d -m 0755 "${data_dir}/puppetserver" \
    && install -d -m 0755 "${data_dir}" \
    # --- config files from tarball ---
    && install -m 0644 ext/config/conf.d/auth.conf                "${etc_dir}/puppetserver/conf.d/auth.conf" \
    && install -m 0644 ext/config/conf.d/ca.conf                  "${etc_dir}/puppetserver/conf.d/ca.conf" \
    && install -m 0644 ext/config/conf.d/global.conf              "${etc_dir}/puppetserver/conf.d/global.conf" \
    && install -m 0644 ext/config/conf.d/metrics.conf             "${etc_dir}/puppetserver/conf.d/metrics.conf" \
    && install -m 0644 ext/config/conf.d/puppetserver.conf        "${etc_dir}/puppetserver/conf.d/puppetserver.conf" \
    && install -m 0644 ext/config/conf.d/web-routes.conf          "${etc_dir}/puppetserver/conf.d/web-routes.conf" \
    && install -m 0644 ext/config/conf.d/webserver.conf           "${etc_dir}/puppetserver/conf.d/webserver.conf" \
    && install -m 0644 ext/config/logback.xml                     "${etc_dir}/puppetserver/logback.xml" \
    && install -m 0644 ext/config/request-logging.xml             "${etc_dir}/puppetserver/request-logging.xml" \
    && install -m 0644 ext/config/services.d/ca.cfg               "${etc_dir}/puppetserver/services.d/ca.cfg" \
    && install -m 0644 ext/system-config/services.d/bootstrap.cfg "${apps_dir}/puppetserver/config/services.d/bootstrap.cfg" \
    # --- jar + CLI tools ---
    && install -m 0644 puppet-server-release.jar                  "${apps_dir}/puppetserver" \
    && install -m 0755 ext/bin/puppetserver                       "${bindir}/puppetserver" \
    && install -m 0755 ext/cli_defaults/cli-defaults.sh           "${apps_dir}/puppetserver/cli" \
    && install -m 0755 ext/cli/ca                                 "${apps_dir}/puppetserver/cli/apps/ca" \
    && install -m 0755 ext/cli/foreground                         "${apps_dir}/puppetserver/cli/apps/foreground" \
    && install -m 0755 ext/cli/gem                                "${apps_dir}/puppetserver/cli/apps/gem" \
    && install -m 0755 ext/cli/irb                                "${apps_dir}/puppetserver/cli/apps/irb" \
    && install -m 0755 ext/cli/ruby                               "${apps_dir}/puppetserver/cli/apps/ruby" \
    # --- symlinks ---
    && ln -s "../apps/puppetserver/bin/puppetserver"              "${symbindir}/puppetserver" \
    && ln -s "../server/apps/puppetserver/bin/puppetserver"       "${uxbindir}/puppetserver" \
    # --- vendored gems ---
    && bash ext/build-scripts/install-vendored-gems.sh \
    # --- puppetdb-termini ---
    && cd /puppetdb-${OPENVOXDB_VERSION} \
    && for f in \
         puppet/face/node/deactivate.rb \
         puppet/face/node/status.rb \
         puppet/functions/puppetdb_query.rb \
         puppet/indirector/catalog/puppetdb.rb \
         puppet/indirector/facts/puppetdb_apply.rb \
         puppet/indirector/facts/puppetdb.rb \
         puppet/indirector/node/puppetdb.rb \
         puppet/indirector/resource/puppetdb.rb \
         puppet/reports/puppetdb.rb \
         puppet/util/puppetdb.rb \
         puppet/util/puppetdb/atom.rb \
         puppet/util/puppetdb/char_encoding.rb \
         puppet/util/puppetdb/command_names.rb \
         puppet/util/puppetdb/command.rb \
         puppet/util/puppetdb/config.rb \
         puppet/util/puppetdb/http.rb; \
       do \
         install -Dm 0644 "$f" "${rubylibdir}/$f"; \
       done \
    # --- cleanup ---
    && rm -rf /openvox-server-*.tar.gz /openvoxdb-*.tar.gz /puppetserver-* /puppetdb-*

################################################################################
# Stage: final — rootless runtime image
################################################################################
FROM base AS final

ARG OPENVOXSERVER_VERSION=8.12.1
ARG R10K_VERSION=5.0.0
ARG OPENVOX_GEM_VERSION=8.21.1

LABEL org.opencontainers.image.title="OpenVox Server" \
      org.opencontainers.image.description="Rootless OpenVox Server for Kubernetes/OpenShift" \
      org.opencontainers.image.vendor="slauger" \
      org.opencontainers.image.url="https://github.com/slauger/openvox-operator" \
      org.opencontainers.image.source="https://github.com/slauger/openvox-operator" \
      org.opencontainers.image.version="${OPENVOXSERVER_VERSION}" \
      org.opencontainers.image.licenses="Apache-2.0"

ENV AUTOSIGN=true \
    CA_ALLOW_SUBJECT_ALT_NAMES=false \
    CA_ENABLED=true \
    CA_TTL=157680000 \
    CA_HOSTNAME=puppet \
    CA_PORT=8140 \
    CERTNAME="" \
    CSR_ATTRIBUTES='{}' \
    DNS_ALT_NAMES="" \
    ENVIRONMENTPATH=/etc/puppetlabs/code/environments \
    HIERACONFIG='$confdir/hiera.yaml' \
    INTERMEDIATE_CA_BUNDLE=/etc/puppetlabs/intermediate/ca.pem \
    INTERMEDIATE_CA_KEY=/etc/puppetlabs/intermediate/key.pem \
    INTERMEDIATE_CA=false \
    INTERMEDIATE_CRL_CHAIN=/etc/puppetlabs/intermediate/crl.pem \
    LOGDIR=/var/log/puppetlabs/puppetserver \
    OPENVOX_REPORTS="puppetdb" \
    OPENVOX_STORECONFIGS_BACKEND="puppetdb" \
    OPENVOX_STORECONFIGS=true \
    OPENVOXDB_SERVER_URLS=https://openvoxdb:8081 \
    OPENVOXSERVER_ENABLE_ENV_CACHE_DEL_API=true \
    OPENVOXSERVER_ENVIRONMENT_TIMEOUT=unlimited \
    OPENVOXSERVER_GRAPHITE_EXPORTER_ENABLED=false \
    OPENVOXSERVER_GRAPHITE_HOST=exporter \
    OPENVOXSERVER_GRAPHITE_PORT=9109 \
    OPENVOXSERVER_HOSTNAME="" \
    OPENVOXSERVER_JAVA_ARGS="-Xms1024m -Xmx1024m" \
    OPENVOXSERVER_MAX_ACTIVE_INSTANCES=1 \
    OPENVOXSERVER_MAX_REQUESTS_PER_INSTANCE=0 \
    OPENVOXSERVER_PORT=8140 \
    PATH=$PATH:/opt/puppetlabs/server/bin:/opt/puppetlabs/puppet/bin:/opt/puppetlabs/bin \
    USE_OPENVOXDB=true

# Copy built artifacts from build stage
COPY --from=build /opt/puppetlabs /opt/puppetlabs
COPY --from=build /etc/puppetlabs /etc/puppetlabs
COPY --from=build /var/log/puppetlabs /var/log/puppetlabs
COPY --from=build /var/run/puppetlabs /var/run/puppetlabs

# Install runtime deps + Ruby gems, then remove build-only deps
RUN microdnf install -y \
        ruby \
        ruby-devel \
        gcc \
        make \
        redhat-rpm-config \
        openssl-devel \
        openssh-clients \
        git \
        findutils \
        hostname \
        sed \
        grep \
        tar \
        gzip \
        shadow-utils \
    && gem install --no-document \
        openvox:${OPENVOX_GEM_VERSION} \
        hocon:1.4.0 \
        r10k:${R10K_VERSION} \
        hiera-eyaml:4.3.0 \
        openvoxserver-ca:3.0.0 \
    && microdnf remove -y \
        ruby-devel \
        gcc \
        make \
        redhat-rpm-config \
        openssl-devel \
    && microdnf clean all \
    # --- symlinks for puppet tooling into expected paths ---
    && mkdir -p /opt/puppetlabs/puppet/bin \
    && ln -sf /usr/local/bin/puppet  /opt/puppetlabs/puppet/bin/puppet \
    && ln -sf /usr/local/bin/facter  /opt/puppetlabs/puppet/bin/facter \
    && ln -sf /usr/bin/ruby          /opt/puppetlabs/puppet/bin/ruby \
    && ln -sf /usr/bin/gem           /opt/puppetlabs/puppet/bin/gem \
    && ln -sf /usr/local/bin/r10k    /opt/puppetlabs/puppet/bin/r10k \
    && ln -sf /usr/local/bin/hiera-eyaml /opt/puppetlabs/puppet/bin/hiera-eyaml \
    # --- install puppet gem into JRuby loadpath ---
    && puppetserver gem install --no-document openvox \
    # --- patch openvoxserver-ca to skip cadir symlink (chown fails rootless) ---
    && find / -path '*/openvoxserver-ca-*/lib/puppetserver/ca/action/setup.rb' \
         -exec sed -i '/Puppetserver::Ca::Utils::Config\.symlink_to_old_cadir/ s/^/# /' {} \; 2>/dev/null \
    || true

# Copy container files
COPY entrypoint.sh /entrypoint.sh
COPY healthcheck.sh /healthcheck.sh
COPY entrypoint.d /entrypoint.d

# Override tarball defaults with our container-specific configs
COPY conf.d/product.conf     /etc/puppetlabs/puppetserver/conf.d/
COPY conf.d/puppetserver.conf /etc/puppetlabs/puppetserver/conf.d/
COPY logback.xml              /etc/puppetlabs/puppetserver/
COPY request-logging.xml      /etc/puppetlabs/puppetserver/
COPY puppet.conf              /etc/puppetlabs/puppet/puppet.conf
COPY puppetdb.conf            /etc/puppetlabs/puppet/puppetdb.conf
COPY puppetserver             /etc/default/puppetserver

RUN chmod +x /entrypoint.sh /healthcheck.sh \
    && find /entrypoint.d -name '*.sh' -exec chmod +x {} +

# Remove USER/GROUP from puppetserver defaults — not needed for rootless
RUN sed -i '/^USER=/d; /^GROUP=/d' /etc/default/puppetserver

# Set HOME explicitly: random UIDs (OpenShift) default HOME to "/"
ENV HOME=/opt/puppetlabs/server/data/puppetserver

# Symlinks so puppet resolves paths correctly for any UID
RUN mkdir -p ${HOME}/.puppetlabs/var \
    && ln -sf /etc/puppetlabs   ${HOME}/.puppetlabs/etc \
    && ln -sf /opt/puppetlabs   ${HOME}/.puppetlabs/opt \
    && ln -sf /var/log/puppetlabs ${HOME}/.puppetlabs/var/log \
    && ln -sf /var/run/puppetlabs ${HOME}/.puppetlabs/var/run

# OpenShift random-UID pattern:
#   group=root(0), mirror user perms to group, set SGID on directories
RUN for d in \
        /etc/puppetlabs \
        /var/log/puppetlabs \
        /var/run/puppetlabs \
        /opt/puppetlabs \
        /entrypoint.d \
    ; do \
        chgrp -R 0 "$d"; \
        chmod -R g=u "$d"; \
        find "$d" -type d -exec chmod g+s {} +; \
    done

USER 1001:0

# k8s uses livenessProbe/readinessProbe/startupProbe — HEALTHCHECK is for Docker/Podman
HEALTHCHECK --interval=20s --timeout=15s --retries=12 --start-period=3m CMD ["/healthcheck.sh"]

EXPOSE 8140

ENTRYPOINT ["/entrypoint.sh"]
