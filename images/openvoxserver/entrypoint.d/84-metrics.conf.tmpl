metrics: {
    server-id: localhost
    registries: {
        puppetserver: {
            reporters: {
                jmx: {
                    enabled: true
                }
                graphite: {
                    enabled: true
                }
            }
        }
    }
    reporters: {
        graphite: {
            host: "GRAPHITE_HOST"
            port: GRAPHITE_PORT
            update-interval-seconds: 5
        }
    }
    metrics-webservice: {
        jolokia: {
            servlet-init-params: {
            }
        }
    }
}
